{
    "builds": [
        {
            "src": "**/*.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}